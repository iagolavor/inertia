{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "inertia-api: stop",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File scripts/stop-api.ps1",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      },
      "problemMatcher": []
    },
    {
      "label": "inertia-api",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File scripts/stop-api.ps1; cargo run -p inertia-api",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "RUST_LOG": "info"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false,
        "group": "inertia-servers"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "inertia-api",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "inertia-api listening"
        }
      }
    },
    {
      "label": "web",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/web"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false,
        "group": "inertia-servers"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:\\s+http"
        }
      }
    },
    {
      "label": "dev",
      "dependsOn": ["inertia-api", "web"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
