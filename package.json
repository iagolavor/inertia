{
  "name": "inertia",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "api": "RUST_LOG=info cargo run -p inertia-api",
    "api:release": "RUST_LOG=info cargo run --release -p inertia-api",
    "api:stop": "node scripts/run-native.mjs stop-api",
    "api:restart": "node scripts/run-native.mjs stop-api && RUST_LOG=info cargo run -p inertia-api",
    "api:window": "node scripts/run-native.mjs start-api-window",
    "relay": "cargo run -p inertia-relay",
    "vps:ssh": "node scripts/run-native.mjs vps-ssh",
    "web": "npm run dev --prefix apps/web",
    "web:build": "npm run build --prefix apps/web",
    "web:preview": "npm run preview --prefix apps/web -- --host",
    "android:sync": "npm run cap:sync --prefix apps/web",
    "android:open": "node scripts/run-native.mjs android-open",
    "android:run": "npm run cap:run:android --prefix apps/web",
    "android:run:device": "node scripts/run-native.mjs android-run-device",
    "android:sdk": "node scripts/run-native.mjs setup-android-sdk",
    "android:reverse": "node scripts/run-native.mjs adb-reverse",
    "android:api:build": "node scripts/run-native.mjs build-android-api",
    "android:package": "node scripts/run-native.mjs package-android",
    "android:stage-b": "npm run android:api:build && npm run web:build && npm run android:package && npm run android:sync",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/package-windows.ps1"
  }
}
