{
  "name": "inertia",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "api": "cargo run -p inertia-api",
    "api:release": "cargo run --release -p inertia-api",
    "api:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-api.ps1",
    "api:restart": "powershell -ExecutionPolicy Bypass -File scripts/stop-api.ps1; cargo run -p inertia-api",
    "api:window": "powershell -ExecutionPolicy Bypass -File scripts/start-api-window.ps1",
    "relay": "cargo run -p inertia-relay",
    "vps:ssh": "powershell -ExecutionPolicy Bypass -File scripts/vps-ssh.ps1",
    "web": "npm run dev --prefix apps/web",
    "web:build": "npm run build --prefix apps/web",
    "web:preview": "npm run preview --prefix apps/web -- --host",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "run:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-windows.ps1",
    "update:windows": "powershell -ExecutionPolicy Bypass -File scripts/update-windows.ps1",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/package-windows.ps1"
  }
}
