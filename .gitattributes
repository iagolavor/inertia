# Normalize text files to LF in the repo; avoid CRLF noise in GitHub diffs on Windows.
* text=auto eol=lf

*.rs text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.svelte text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts need LF even on Windows contributors
*.sh text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
