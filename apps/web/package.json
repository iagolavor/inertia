{
  "name": "inertia-web",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "debug:profile": "node scripts/debug-profile.mjs",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:run:android": "npm run cap:sync && cap run android",
    "android:reverse": "npm run android:reverse --prefix ../.."
  },
  "dependencies": {
    "@capacitor/android": "^7.2.0",
    "@capacitor/core": "^7.2.0",
    "fflate": "^0.8.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "@puppeteer/browsers": "^2.13.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/qrcode": "^1.5.5",
    "puppeteer-core": "^24.43.1",
    "qrcode": "^1.5.4",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.4"
  }
}
